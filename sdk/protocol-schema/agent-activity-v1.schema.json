{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effective.work/schemas/agent-activity/v1.json",
  "title": "Agent Activity Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "event_id", "provider", "adapter_id",
    "adapter_version", "source_kind", "instance_id", "session_id",
    "kind", "occurred_at", "observed_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "event_id": { "type": "string", "minLength": 1, "maxLength": 512 },
    "provider": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "adapter_id": { "type": "string", "minLength": 1 },
    "adapter_version": { "type": "string", "minLength": 1 },
    "source_kind": { "enum": ["native_hook", "official_api", "session_log", "process_heuristic"] },
    "instance_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "turn_id": { "type": ["string", "null"] },
    "correlation_id": { "type": ["string", "null"] },
    "sequence": { "type": ["integer", "null"], "minimum": 0 },
    "kind": {
      "enum": [
        "adapter.connected", "adapter.disconnected", "session.started",
        "session.stopped", "user.prompted", "model.working", "tool.started",
        "tool.finished", "tool.failed", "approval.required", "approval.resolved",
        "run.completed", "run.aborted", "run.failed", "heartbeat"
      ]
    },
    "occurred_at": { "type": "string", "format": "date-time" },
    "observed_at": { "type": "string", "format": "date-time" },
    "tool": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["name", "category"],
      "properties": {
        "name": { "type": "string", "maxLength": 128 },
        "category": { "type": "string", "maxLength": 64 }
      }
    },
    "attributes": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "source_kind": { "const": "process_heuristic" } },
        "required": ["source_kind"]
      },
      "then": {
        "properties": {
          "kind": {
            "enum": ["adapter.connected", "adapter.disconnected", "heartbeat"]
          }
        }
      }
    }
  ]
}
